#
# nginx inbound reverse proxy with OTel tracing and TLS termination.
# TLS certificates are issued and renewed by the nginx-acme module
# (ngx_http_acme_module) using the ACME HTTP-01 challenge on port 80.
# Template variables substituted at startup: $BACKEND_HOST, $BACKEND_PORT,
# $ACME_DOMAIN, $ACME_EMAIL

load_module modules/ngx_otel_module.so;
load_module modules/ngx_http_acme_module.so;

events {
    worker_connections 1024;
}

http {
    # Required by nginx-acme for DNS lookups during ACME protocol exchanges
    resolver 1.1.1.1 8.8.8.8 valid=300s ipv6=off;
    resolver_timeout 5s;

    # ── ACME issuer (Let's Encrypt) ────────────────────────────────────────────
    acme_issuer letsencrypt {
        uri        https://acme-v02.api.letsencrypt.org/directory;
        contact    ${ACME_EMAIL};
        state_path /var/cache/nginx/acme-letsencrypt;
        accept_terms_of_service;
    }

    # Shared memory zone for coordinating cert state across worker processes
    acme_shared_zone zone=ngx_acme_shared:1M;

    # ── OTel exporter (gRPC to otel-collector) ─────────────────────────────────
    otel_exporter {
        endpoint otel-collector:4317;
    }

    # ── Logging ────────────────────────────────────────────────────────────────
    access_log /dev/stdout;
    error_log  /dev/stderr warn;

    # ── Upstream: backend service ──────────────────────────────────────────────
    upstream backend {
        server ${BACKEND_HOST}:${BACKEND_PORT};
        keepalive 32;
    }

    # ── HTTPS server ───────────────────────────────────────────────────────────
    server {
        listen 19000 ssl;
        server_name ${ACME_DOMAIN};

        # nginx-acme manages the certificate for this domain
        acme_certificate letsencrypt;

        ssl_certificate       $acme_certificate;
        ssl_certificate_key   $acme_certificate_key;
        # Avoid parsing the certificate object on every request
        ssl_certificate_cache max=2;

        ssl_protocols       TLSv1.2 TLSv1.3;
        ssl_ciphers         HIGH:!aNULL:!MD5;
        ssl_session_cache   shared:SSL:10m;
        ssl_session_timeout 10m;

        # Emit one OTel span per inbound request
        otel_trace         on;
        otel_trace_context propagate;
        otel_span_name     "inbound.request";

        location / {
            proxy_pass         http://backend;
            proxy_http_version 1.1;
            proxy_set_header   Upgrade         $http_upgrade;
            proxy_set_header   Connection      "upgrade";
            proxy_set_header   Host            $host;
            proxy_set_header   X-Real-IP       $remote_addr;
            proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;

            # Per-request span attributes
            otel_span_attr http.client_ip  $remote_addr;
            otel_span_attr http.method     $request_method;
            otel_span_attr http.path       $request_uri;
            otel_span_attr http.status     $status;
        }
    }

    # ── HTTP server — required for ACME HTTP-01 challenge ──────────────────────
    # nginx-acme intercepts /.well-known/acme-challenge/ requests automatically.
    server {
        listen 80;
        server_name ${ACME_DOMAIN};

        location / {
            return 404;
        }
    }
}
