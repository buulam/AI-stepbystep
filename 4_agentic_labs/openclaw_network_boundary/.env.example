# Copy this file to .env and fill in all values before running docker compose up.
# .env is git-ignored and must never be committed.

# ── OpenClaw gateway ─────────────────────────────────────────────────────────
# Token required to authenticate with the OpenClaw UI and API
GATEWAY_TOKEN=replace-with-a-secure-random-token

# ── Platform / runtime ───────────────────────────────────────────────────────
# Jetson (arm64 + NVIDIA GPU): set to nvidia
# x86 (CPU or no NVIDIA Container Toolkit): leave empty
OLLAMA_RUNTIME=

# ── Ollama model selection ────────────────────────────────────────────────────
# The model ollama will pull on first start and that OpenClaw will use
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_CHAT_MODEL=qwen2.5:3b

# ── Network / host ────────────────────────────────────────────────────────────
# IP address or hostname of the machine running Docker.
# Used in CORS allowed origins so the browser can reach the gateway.
OPENCLAW_HOST=replace-with-host-ip-or-hostname
OPENCLAW_HOST_PORT=19000

# ── TLS / ACME (nginx-acme module — Let's Encrypt HTTP-01) ──────────────────
# Port 80 on ACME_DOMAIN must be publicly reachable from the internet.
ACME_DOMAIN=replace-with-your-domain
ACME_EMAIL=replace-with-your-email
